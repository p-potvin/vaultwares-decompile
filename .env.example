# ─────────────────────────────────────────────────────────────────
# VaultWares Decompile — Environment Configuration Template
# Copy this file to .env and fill in your local values.
# NEVER commit the .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Local AI Backend ───────────────────────────────────────────────
# URL of your locally running Ollama instance.
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# URL of a llama.cpp OpenAI-compatible server (fallback if Ollama is not available).
# Default: http://localhost:8080
LLAMACPP_BASE_URL=http://localhost:8080

# Default model to use for AI renaming when none is selected in the UI.
# Must be a model that has been pulled via: ollama pull <model>
DEFAULT_AI_MODEL=llama3

# ── Crawler ────────────────────────────────────────────────────────
# Maximum pages to crawl per session (safety cap).
CRAWL_MAX_PAGES=200

# Maximum concurrent browser tabs during crawl.
CRAWL_MAX_CONCURRENCY=3

# ── Vault (Encrypted Storage) ──────────────────────────────────────
# Directory where encrypted session vaults are stored.
# Default: ~/.vaultwares-decompile/vault
# VAULT_DIR=/path/to/custom/vault

# ── Redis (optional — only needed for multi-agent coordination) ────
# Redis connection URL for the vaultwares-agentciation framework.
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Packaging (macOS code signing — only needed for releases) ──────
# APPLE_ID=your@apple.id
# APPLE_ID_PASSWORD=app-specific-password
# APPLE_TEAM_ID=XXXXXXXXXX
