{
  "name": "deconstructed",
  "version": "0.1.0",
  "description": "VaultWares security research tool — API mapping, JS deobfuscation, and AI-powered code reconstruction",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src --ext .js,.jsx"
  },
  "keywords": [
    "security",
    "research",
    "deobfuscation",
    "api-mapping",
    "electron",
    "vaultwares"
  ],
  "author": "VaultWares",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "crawlee": "^3.11.0",
    "diff": "^5.2.0",
    "electron-updater": "^6.1.0",
    "ioredis": "^5.3.2",
    "js-beautify": "^1.15.1",
    "mlkem": "^2.7.0",
    "playwright": "^1.44.0",
    "prettier": "^3.2.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "source-map": "^0.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.vaultwares.deconstructed",
    "productName": "Deconstructed",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}
